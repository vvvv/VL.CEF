<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>VL.CEF.win-x64</id>
    <version>$version$</version>
    <authors>$authors$</authors>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <license type="expression">$license$</license>
    <projectUrl>$projectUrl$</projectUrl>
    <repository type="git" url="$repositoryurl$" />
    <description>Windows x64 native renderer binaries for VL.CEF. This package is automatically referenced by VL.CEF and should not be referenced directly.</description>
    <copyright>$copyright$</copyright>
    <dependencies>
      <group targetFramework="net8.0">
      </group>
    </dependencies>
  </metadata>
  <files>
    <file src="bin\runtimes\win-x64\**" target="renderer\runtimes\win-x64" />
    <file src="buildTransitive\VL.CEF.win-x64.targets" target="buildTransitive\VL.CEF.win-x64.targets" />
  </files>
</package>
